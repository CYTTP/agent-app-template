{
  "plugins": ["@prettier/plugin-oxc", "prettier-plugin-tailwindcss"],
  "tailwindAttributes": ["className", "classNames", "rootClassName", "rowClassName"],
  "tailwindFunctions": ["clsx"],
  "arrowParens": "always",
  "endOfLine": "lf",
  "printWidth": 100,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all"
}
