{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@shared/main": ["../../packages/shared/src/index.ts"],
      "@shared/main/*": ["../../packages/shared/src/*"],
      "drizzle-orm/sqlite-core": ["../../node_modules/drizzle-orm/sqlite-core"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*"]
}
